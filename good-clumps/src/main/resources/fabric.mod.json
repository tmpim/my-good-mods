{
  "schemaVersion": 1,
  "id": "good-clumps",
  "version": "${version}",

  "name": "Good Clumps",
  "description": "Merges nearby dropped items together",
  "authors": [
    "tmpim",
    "Lemmmy",
    "Lignum"
  ],
  "contact": {
    "sources": "https://github.com/tmpim/my-good-mods"
  },

  "license": "MIT",
  "icon": "assets/good-clumps/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodclumps.GoodClumps"
      }
    ],
    "gcapi3": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodclumps.GoodClumps"
      }
    ],
    "data": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodclumps.data.GoodClumpsData"
      }
    ]
  },

  "mixins": [
    "good-clumps.mixins.json"
  ],

  "accessWidener": "good-clumps.classtweaker",

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "java": ">=${javaVersion}",
    "stationapi": ">=${stationApiMin}",
    "fabricloader": ">=${fabricLoaderMin}",
    "fabric-language-kotlin": "*",
    "gcapi3": ">=${gcapiMin}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
