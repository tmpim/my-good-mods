{
  "schemaVersion": 1,
  "id": "good-mod-template",
  "version": "${version}",

  "name": "Good Mod Template",
  "description": "great",
  "authors": [
    "tmpim"
  ],
  "contact": {
    "sources": "https://github.com/tmpim/my-good-mods"
  },

  "license": "MIT",
  "icon": "assets/good-mod-template/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodmodtemplate.GoodModTemplate"
      }
    ],
    "stationapi:event_bus_client": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodmodtemplate.GoodModTemplateClient"
      }
    ],
    "gcapi3": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodmodtemplate.GoodModTemplate"
      }
    ],
    "data": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodmodtemplate.data.GoodModTemplateData"
      }
    ]
  },

  "mixins": [
    "good-mod-template.mixins.json"
  ],

  "accessWidener": "good-mod-template.classtweaker",

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "java": ">=${javaVersion}",
    "stationapi": ">=${stationApiMin}",
    "fabricloader": ">=${fabricLoaderMin}",
    "fabric-language-kotlin": "*",
    "gcapi3": ">=${gcapiMin}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
