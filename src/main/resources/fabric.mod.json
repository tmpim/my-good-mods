{
  "schemaVersion": 1,
  "id": "mygoodmod",
  "version": "${version}",

  "name": "My good mod",
  "description": "great",
  "authors": [
    "Lemmmy"
  ],
  "contact": {
    "sources": "https://github.com/tmpim/MyGoodMod"
  },

  "license": "MIT",
  "icon": "assets/mygoodmod/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.mygoodmod.MyGoodMod"
      }
    ],
    "stationapi:event_bus_client": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.mygoodmod.MyGoodModClient"
      }
    ],
    "stationapi:event_bus_server": [],
    "gcapi3": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.mygoodmod.MyGoodMod"
      }
    ],
    "data": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.mygoodmod.data.MyGoodModData"
      }
    ]
  },

  "mixins": [
    "mygoodmod.mixins.json"
  ],

  "accessWidener": "mygoodmod.accesswidener",

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "stationapi": "2.*",
    "fabric-language-kotlin": "*"
  },
  "recommends": {
    "modmenu": "*"
  }
}
