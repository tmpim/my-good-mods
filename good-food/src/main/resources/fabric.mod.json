{
  "schemaVersion": 1,
  "id": "good-food",
  "version": "${version}",

  "name": "Good Food",
  "description": "Wonderful bagels",
  "authors": [
    "tmpim",
    "hugeblank"
  ],
  "contact": {
    "sources": "https://github.com/tmpim/my-good-mods"
  },

  "license": "MIT",
  "icon": "assets/good-food/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodfood.GoodFood"
      }
    ],
    "stationapi:event_bus_client": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodfood.GoodFoodClient"
      }
    ],
    "stationapi:event_bus_server": [],
    "data": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodfood.data.GoodFoodData"
      }
    ]
  },

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "stationapi": ">=${stationApiMin}",
    "fabricloader": ">=${fabricLoaderMin}",
    "fabric-language-kotlin": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}
