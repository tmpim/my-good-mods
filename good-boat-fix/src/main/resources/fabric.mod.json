{
  "schemaVersion": 1,
  "id": "good-boat-fix",
  "version": "${version}",

  "name": "Good Boat Fix",
  "description": "Boats drop boats instead of sticks and planks when broken.",
  "authors": [
    "tmpim",
    "Lignum"
  ],
  "contact": {
    "sources": "https://github.com/tmpim/my-good-mods"
  },

  "license": "MIT",
  "icon": "assets/good-boat-fix/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodboatfix.GoodBoatFix"
      }
    ],
    "gcapi3": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodboatfix.GoodBoatFix"
      }
    ],
    "data": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodboatfix.data.GoodBoatFixData"
      }
    ]
  },

  "mixins": [
    "good-boat-fix.mixins.json"
  ],

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "java": ">=${javaVersion}",
    "stationapi": ">=${stationApiMin}",
    "fabricloader": ">=${fabricLoaderMin}",
    "fabric-language-kotlin": "*",
    "gcapi3": ">={gcapiMin}"
  }
}
