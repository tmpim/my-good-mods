{
  "schemaVersion": 1,
  "id": "good-death-messages",
  "version": "${version}",

  "name": "Good Death Messages",
  "description": "Implements death messages faithful to newer versions of vanilla Minecraft.",
  "authors": [
    "tmpim",
    "hugeblank"
  ],
  "contact": {
    "sources": "https://github.com/tmpim/my-good-mods"
  },

  "license": "MIT",
  "icon": "assets/good-death-messages/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.gooddeathmessages.GoodDeathMessages"
      }
    ],
    "gcapi3": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.gooddeathmessages.GoodDeathMessages"
      }
    ],
    "data": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.gooddeathmessages.data.GoodDeathMessagesData"
      }
    ]
  },

  "mixins": [
    "good-death-messages.mixins.json"
  ],

  "accessWidener": "good-death-messages.classtweaker",

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "java": ">=${javaVersion}",
    "stationapi": ">=${stationApiMin}",
    "fabricloader": ">=${fabricLoaderMin}",
    "fabric-language-kotlin": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}
