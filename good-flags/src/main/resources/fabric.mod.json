{
  "schemaVersion": 1,
  "id": "good-flags",
  "version": "${version}",

  "name": "Good Flags",
  "description": "Placeable flags that you can paint on.",
  "authors": [
    "tmpim"
  ],
  "contact": {
    "sources": "https://github.com/tmpim/my-good-mods"
  },

  "license": "MIT",
  "icon": "assets/good-flags/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodflags.GoodFlags"
      }
    ],
    "stationapi:event_bus_client": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodflags.GoodFlagsClient"
      }
    ],
    "stationapi:event_bus_server": [],
    "gcapi3": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodflags.GoodFlags"
      }
    ],
    "data": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodflags.data.GoodFlagsData"
      }
    ]
  },

  "mixins": [
    "good-flags.mixins.json"
  ],

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "stationapi": ">=${stationApiMin}",
    "fabricloader": ">=${fabricLoaderMin}",
    "fabric-language-kotlin": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}