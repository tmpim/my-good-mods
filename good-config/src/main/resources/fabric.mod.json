{
  "schemaVersion": 1,
  "id": "good-config",
  "version": "${version}",

  "name": "Good Config",
  "description": "great",
  "authors": [
    "tmpim"
  ],
  "contact": {
    "sources": "https://github.com/tmpim/my-good-mods"
  },

  "license": "MIT",
  "icon": "assets/good-config/icon.png",

  "environment": "*",
  "entrypoints": {
    "preLaunch": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodconfig.GoodConfig"
      }
    ],
    "stationapi:event_bus_client": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodconfig.GoodConfigClient"
      }
    ],
    "data": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodconfig.data.GoodConfigData"
      }
    ],
    "glassnetworking": [
      {
        "adapter": "kotlin",
        "value": "pw.tmpim.goodconfig.net.GoodConfigNetworking"
      }
    ]
  },

  "mixins": [
    "good-config.mixins.json"
  ],

  "accessWidener": "good-config.classtweaker",

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "java": ">=${javaVersion}",
    "stationapi": ">=${stationApiMin}",
    "fabricloader": ">=${fabricLoaderMin}",
    "fabric-language-kotlin": "*",
    "glassnetworking": ">=${glassNetworkingMin}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
